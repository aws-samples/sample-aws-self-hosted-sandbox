#!/usr/bin/env bash
#
# pre-commit hook —— 提交前依次执行：
#   1) Claude AI code review（发现严重问题时阻断提交）；
#   2) 依据本次改动自动同步项目文档（README 中/英文 + docs/deploy.md 等，不阻断提交）。
# 本 hook 位于版本库内的 .githooks/,由 core.hooksPath 生效(运行 scripts/install-hooks.sh 启用)。
#
set -uo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

# ---- 1. AI code review（可阻断）---------------------------------------------
# 允许临时跳过：SKIP_CODE_REVIEW=1 git commit ...
if [[ "${SKIP_CODE_REVIEW:-}" == "1" ]]; then
  echo "[pre-commit] SKIP_CODE_REVIEW=1，跳过 AI code review。"
else
  REVIEW_SCRIPT="$REPO_ROOT/scripts/code-review.sh"
  if [[ -x "$REVIEW_SCRIPT" ]]; then
    "$REVIEW_SCRIPT" || exit $?   # 审查判定 BLOCK 时退出码非 0，阻断提交
  else
    echo "[pre-commit] 未找到可执行的 $REVIEW_SCRIPT，跳过审查。" >&2
  fi
fi

# ---- 2. 自动同步文档（不阻断）---------------------------------------------
# 允许临时跳过：SKIP_DOC_UPDATE=1 git commit ...
DOC_SCRIPT="$REPO_ROOT/scripts/update-docs.sh"
if [[ -x "$DOC_SCRIPT" ]]; then
  "$DOC_SCRIPT" || true          # 文档更新始终不阻断提交
else
  echo "[pre-commit] 未找到可执行的 $DOC_SCRIPT，跳过文档更新。" >&2
fi

exit 0
